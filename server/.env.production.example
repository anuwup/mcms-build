# Production server environment. Copy to .env and set values.

PORT=5001
NODE_ENV=production

# Frontend origin (for CORS and emails). No trailing slash.
CLIENT_URL=https://anupchavan.com

# Required for auth. Use a long random string in production.
JWT_SECRET=your_long_random_secret_here

# MongoDB (required for persistent users/meetings)
MONGO_URI=mongodb://127.0.0.1:27017/mcms_db

# Optional: email (SendGrid or SMTP)
# SENDGRID_API_KEY=...
# SMTP_HOST=...
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# SMTP_FROM=...

# Optional: Sarvam AI for live transcription
# SARVAM_API_KEY=...

# Optional: public URL of this server (for RSVP links in emails)
# SERVER_URL=https://anupchavan.com
