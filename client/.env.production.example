# Production build will use this when you run: vite build
# Copy to .env.production and set your API URL.

# Full URL to your API (same origin or subdomain)
# Same origin (recommended if API is on anupchavan.com):
VITE_API_URL=https://anupchavan.com/api

# If API is on a subdomain:
# VITE_API_URL=https://api.anupchavan.com/api
